        "./payment_intent.ts"
      ],
      "@/modules/checkout/payment_confirm": [
        "./payment_confirm.ts"
      ],
      "@/db/client": [
        "./test_stubs/db-client.ts"
      ],
      "@/db/schema": [
        "./test_stubs/db-schema.ts"
      ],
      "@/modules/common/idempotency": [
        "./test_stubs/idempotency.ts"
      ]
    }
  },
  "include": [
    "./*.ts",
    "./test_stubs/*.ts"
  ]
}
